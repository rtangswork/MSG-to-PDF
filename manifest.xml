<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>b2c3d4e5-f6a7-8901-bcde-f12345678901</Id>
  <Version>1.0.0.1</Version>
  <ProviderName>Glenview Capital</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="Save as PDF"/>
  <Description DefaultValue="Convert this email to a PDF and save to your Downloads folder."/>

  <IconUrl DefaultValue="https://rtangswork.github.io/MSG-to-PDF/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://rtangswork.github.io/MSG-to-PDF/icon-80.png"/>
  <SupportUrl DefaultValue="https://rtangswork.github.io/MSG-to-PDF"/>

  <AppDomains>
    <AppDomain>https://rtangswork.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://rtangswork.github.io/MSG-to-PDF/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0">
        <bt:Set Name="Mailbox" MinVersion="1.3"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="GlenviewGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="SavePDFButton">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" size="16" resid="Icon16"/>
                    <bt:Image xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" size="32" resid="Icon32"/>
                    <bt:Image xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskPaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0">
      <bt:Urls>
        <bt:Url id="TaskPaneUrl"  DefaultValue="https://rtangswork.github.io/MSG-to-PDF/taskpane.html"/>
        <bt:Url id="FunctionFile" DefaultValue="https://rtangswork.github.io/MSG-to-PDF/function-file.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"  DefaultValue="Email Tools"/>
        <bt:String id="ButtonLabel" DefaultValue="Save as PDF"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonDesc" DefaultValue="Convert this email to a PDF and save to your Downloads folder."/>
      </bt:LongStrings>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://rtangswork.github.io/MSG-to-PDF/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://rtangswork.github.io/MSG-to-PDF/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://rtangswork.github.io/MSG-to-PDF/icon-80.png"/>
      </bt:Images>
    </Resources>
  </VersionOverrides>

</OfficeApp>
